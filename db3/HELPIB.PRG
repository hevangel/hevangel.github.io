*** Input Book Help
clear
set color to W+/B
clear
set color to G+/W
@0,0 clear to 0,79
@0,43 say "Appleby Library System Version 2.01r"
set color to GR+/W
@0,1 say "<< Help of Input New Book >>"
set color to N+/W
@24,0 clear to 24,79
@24,29 say "Press <Enter> to continue"

set color to GR+/B
@23,1 say "Program by Luxi-Soft Co. Ltd."
@23,59 say "Copyright, Oct. 1994"


set color to W+/B

@2,8 say "    In Appleby Library System, the computer database contain the"
@3,8 say "Title, Author, ISBN number, Publisher and Library Code (libcode)"
@4,8 say "of the book for record."

@5,8 say "    The Input New Book Screen allow users to add a book to the"
@6,8 say "database.  First the user should input the title, author, ISBN"
@7,8 say "and publisher to the appropriate field.  The libcode will be"
@8,8 say "generated by the program.  No book will have the same libcode."
@9,8 say "The libcode is use to identify the book, so please put down the"
@10,8 say "libcode on the coresponding book also."

@12,8 say "    After you entered the data of the book, you can select the"
@13,8 say "choice 'Save and Exit', 'Next', 'Edit', 'Cancel' by pressing"
@14,8 say "the cursor keys, and choose by pressing <Enter>"
@15,8 say "    'Save and Exit' will save the data you entered and go back"
@16,8 say "to the configuration menu."
@17,8 say "    'Next' will save the data you entered and allow you enter"
@18,8 say "another set of new data."
@19,8 say "    'Edit' let you edit the data you just entered."
@20,8 say "    'Cancel' will NOT save the data you had entered and go back" 
@21,8 say "to the previous menu."


key = 0
do while key = 0
    key = inkey()
enddo
